---
layout: layouts/base.njk
title: Blog
permalink: /blog/
---
<div class="blog-container">
  <header class="blog-header">
    <h1>{{ "blog.title" | t(lang) | default("Blog") }}</h1>
    <p class="blog-subtitle">{{ "blog.subtitle" | t(lang) | default(site.description) }}</p>
  </header>

  <nav class="blog-nav">
    <a href="{% if lang and lang != defaultLanguage %}/{{ lang }}{% endif %}/blog/tags/" class="blog-nav-link">{{ "blog.tags" | t(lang) | default("Tags") }}</a>
    <a href="{% if lang and lang != defaultLanguage %}/{{ lang }}{% endif %}/blog/categories/" class="blog-nav-link">{{ "blog.categories" | t(lang) | default("Categories") }}</a>
  </nav>

  <div class="post-list">
    {%- set postCollection = collections.posts %}
    {%- if lang and lang != defaultLanguage %}
      {%- set postCollection = collections[lang + "posts"] | default(collections.posts) %}
    {%- endif %}
    {%- for post in postCollection | reverse -%}
    <article class="blog-post">
      <a href="{{ post.url }}" class="post-title">{{ post.data.title }}</a>
      <div class="post-meta">
        <time datetime="{{ post.date | isoDate }}">{{ post.date | dateFormat(lang) }}</time>
        {% if post.data.author %} · {{ post.data.author }}{% endif %}
        {% if post.data.category %} · <a href="{% if lang and lang != defaultLanguage %}/{{ lang }}{% endif %}/blog/categories/{{ post.data.category | slugify }}/">{{ post.data.category | capitalize }}</a>{% endif %}
      </div>
      {% if post.data.excerpt or post.data.description %}<p class="post-excerpt">{{ post.data.excerpt | default(post.data.description) }}</p>{% endif %}
      {% if post.data.tags %}
      <div class="post-tags">
        {% for tag in post.data.tags %}
        {% if tag != 'post' and tag != 'posts' %}
        <a href="{% if lang and lang != defaultLanguage %}/{{ lang }}{% endif %}/blog/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a>
        {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </article>
    {%- endfor -%}
  </div>

  {% if postCollection | length == 0 %}
  <div class="blog-empty">
    <p>{{ "blog.empty" | t(lang) | default("No blog posts yet. Check back soon!") }}</p>
  </div>
  {% endif %}
</div>
